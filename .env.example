# ===== WEALTHSPHERE ENVIRONMENT TEMPLATE =====
# Copie este arquivo para .env.local e preencha com seus valores
# IMPORTANTE: .env.local NÃO deve ser commitado para git

# ===== ENVIRONMENT =====
NODE_ENV=development
# production | development | test

# ===== SERVER =====
PORT=5000
# Porta em que o backend vai escutar

# ===== DATABASE =====
MONGO_URI=mongodb://localhost:27017/wealthsphere
# Conexão com MongoDB local ou MongoDB Atlas

# ===== AUTHENTICATION =====
JWT_SECRET=your-super-secret-jwt-key-change-this
# Chave secreta para assinar JWT tokens (mínimo 32 caracteres em production)

SESSION_SECRET=your-super-secret-session-key-change-this
# Chave secreta para sessões (mínimo 32 caracteres em production)

# ===== EXTERNAL APIS =====
STEAM_API_KEY=your-steam-api-key-here
# Obtenha em https://steamcommunity.com/dev

# ===== FRONTEND CONFIGURATION =====
FRONTEND_URL=http://localhost:4200
# URL do frontend (usado para CORS no backend)

CLIENT_ORIGIN=http://localhost:4200,http://localhost:4201
# URLs permitidas (CORS) - separadas por vírgula

SERVER_URL=http://localhost:5000
# URL do backend (usado pelo frontend para requisições)

API_URL=http://localhost:5000/api
# Endpoint da API (usado pelo Angular)

# ===== SECURITY CONFIGURATION =====
# Estas variáveis controlam comportamentos de segurança críticos

# Steam token handling
STEAM_TOKEN_POST_BODY=true
# true = enviar token no POST body (SEGURO - production)
# false = enviar token em query string (DEV ONLY - inseguro)

# Auth interceptor mode
AUTH_INTERCEPTOR_STRICT=true
# true = interceptor apenas para APIs internas (SEGURO)
# false = interceptor em todas as requisições (pode vazar token)

# Token refresh flow
TOKEN_REFRESH_ENABLED=true
# true = usar refresh token flow (RECOMENDADO)
# false = desabilitar (menos seguro)

TOKEN_EXPIRY_MINUTES=60
# Tempo de expiração do access token em minutos

TOKEN_REFRESH_EXPIRY_DAYS=7
# Tempo de expiração do refresh token em dias

# Steam rate limiting
STEAM_RATE_LIMIT=10
# Máximo de requisições Steam por IP por minuto

# ===== PRODUCTION HARDENING CHECKLIST =====
# Antes de fazer deploy em production:
# ☐ JWT_SECRET é uma string aleatória de 64+ caracteres
# ☐ SESSION_SECRET é uma string aleatória de 64+ caracteres
# ☐ MONGO_URI aponta para produção (MongoDB Atlas com credenciais)
# ☐ NODE_ENV=production
# ☐ STEAM_TOKEN_POST_BODY=true
# ☐ AUTH_INTERCEPTOR_STRICT=true
# ☐ TOKEN_REFRESH_ENABLED=true
# ☐ SERVER_URL aponta para domínio de produção com HTTPS
# ☐ CLIENT_ORIGIN inclui apenas domínios permitidos
# ☐ HTTPS está ativado no servidor
